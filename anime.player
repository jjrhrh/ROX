<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>مشاهدة — アニメ·KO</title>
<link rel="stylesheet" href="css/style.css">
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;900&display=swap" rel="stylesheet">
<!-- HLS.js لتشغيل روابط M3U8 -->
<script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
</head>
<body class="player-page">

<nav>
  <a href="index.html" class="back-btn">← رجوع</a>
  <div class="logo">アニメ·<em>KO</em></div>
</nav>

<div class="player-layout">

  <!-- VIDEO AREA -->
  <div class="video-section">
    <div class="video-wrap" id="videoWrap">
      <div class="video-placeholder" id="videoPlaceholder">
        <div class="big-play" id="bigPlayBtn">▶</div>
        <p id="placeholderText">اختر سيرفر وحلقة للمشاهدة</p>
      </div>
    </div>

    <!-- SERVER SELECTOR -->
    <div class="server-bar">
      <span class="server-label">🖥️ السيرفر:</span>
      <div class="servers" id="serverBtns">
        <!-- تتولد تلقائياً -->
      </div>
    </div>

    <!-- QUALITY -->
    <div class="quality-bar">
      <span class="server-label">📺 الجودة:</span>
      <button class="qbtn active" onclick="setQuality('auto',this)">Auto</button>
      <button class="qbtn" onclick="setQuality('1080',this)">1080p</button>
      <button class="qbtn" onclick="setQuality('720',this)">720p</button>
      <button class="qbtn" onclick="setQuality('480',this)">480p</button>
      <button class="qbtn" onclick="setQuality('360',this)">360p</button>
    </div>
  </div>

  <!-- ANIME INFO + EPISODES -->
  <div class="info-section">
    <div class="anime-card-big" id="animeCardBig">
      <div class="loading"><div class="spinner"></div></div>
    </div>

    <!-- EPISODES -->
    <div class="eps-box">
      <div class="eps-title">📋 الحلقات</div>
      <div class="eps-grid" id="epsGrid">
        <div class="loading"><div class="spinner"></div></div>
      </div>
    </div>

    <!-- CUSTOM URL -->
    <div class="custom-box">
      <div class="eps-title">🔗 رابط مخصص (MP4 / M3U8 / Iframe)</div>
      <div class="custom-row">
        <input type="text" id="customUrl" class="custom-input"
          placeholder="https://... الصق رابط فيديو مباشر أو iframe"
          dir="ltr"/>
        <button class="custom-go" onclick="loadCustomUrl()">▶</button>
      </div>
    </div>
  </div>

</div>

<script src="js/main.js"></script>
<script src="js/player.js"></script>
</body>
</html>
